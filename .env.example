# === Legacy (existing platform) ===
PORT=3000
DATA_DIR=./data
LEGACY_INTEGRATION_API_KEY=change-me
LEGACY_WEBHOOK_URL=
LEGACY_WEBHOOK_SECRET=
LEGACY_WEBHOOK_STATUSES=ready_for_crm,needs_clarification
LEGACY_WEBHOOK_INTERVAL_MS=15000
LEGACY_WEBHOOK_TIMEOUT_MS=10000
PROJECT2_GOOGLE_CREDENTIALS_B64=
PROJECT2_SEEN_B64=
PROJECT2_LOG_B64=

# === New Email Module ===

# PostgreSQL
DATABASE_URL=postgresql://pochta:password@localhost:5432/pochta

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production

# S3-compatible storage (Tigris on Railway / MinIO locally)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=pochta
S3_SECRET_KEY=change-me
S3_BUCKET=pochta-emails
S3_REGION=us-east-1

# CORS
CORS_ORIGIN=http://localhost:3000

# API
API_PORT=4000

# LLM (optional — for AI-powered classification/extraction)
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_BASE_URL=https://api.anthropic.com

# Feature flags
SYNC_DRY_RUN=true
AI_ENABLED=false
SHADOW_MODE=true

# Logging
LOG_LEVEL=info
