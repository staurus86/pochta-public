{
  "name": "pochta-platform",
  "version": "0.2.0",
  "private": true,
  "description": "MVP platform for inbound email parsing and CRM routing",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "node --watch src/server.js",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:worker": "npm run dev -w apps/worker",
    "build:web": "npm run build -w apps/web",
    "build:api": "npm run build -w apps/api",
    "build:worker": "npm run build -w apps/worker",
    "start": "node src/server.js",
    "start:api": "npm run start -w apps/api",
    "start:web": "npm run start -w apps/web",
    "start:worker": "npm run start -w apps/worker",
    "db:generate": "npm run generate -w packages/db",
    "db:migrate": "npm run migrate -w packages/db",
    "db:push": "npm run push -w packages/db",
    "db:studio": "npm run studio -w packages/db",
    "test": "node tests/email-analyzer.test.js && node tests/project-schedule.test.js && node tests/mailbox-config-parser.test.js && node tests/detection-kb.test.js",
    "test:api": "npm test -w apps/api",
    "test:web": "npm test -w apps/web"
  },
  "engines": {
    "node": ">=20"
  }
}
